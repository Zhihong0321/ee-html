# Required: shared secret agents must send to write/manage apps.
# Generate one with:  openssl rand -hex 32
API_KEY=change-me

# Local-only. On Railway this is provided automatically.
PORT=3000

# Where app files are stored. On Railway, set your volume mount path here.
DATA_DIR=./data

# Optional: max upload size in bytes (default 50 MB).
MAX_UPLOAD_BYTES=52428800

# Optional: force the base URL reported back to callers.
# On Railway, RAILWAY_PUBLIC_DOMAIN is used automatically if this is unset.
# PUBLIC_BASE_URL=https://your-app.up.railway.app
